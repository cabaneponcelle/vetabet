# Copiez ce fichier en « .env » et remplissez les valeurs.

# URL PostgreSQL (Neon, Supabase, ou serveur local)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Secret de session (générer : node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
AUTH_SECRET="changez-moi"
AUTH_TRUST_HOST="true"

# SMTP — laisser vide en développement (emails simulés dans la console)
SMTP_HOST=""
SMTP_PORT=""
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Planning Assistovet <no-reply@assistovet.local>"
